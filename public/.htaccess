RewriteEngine On

# Beveilig broncode mappen
RewriteRule ^(src|migrations|scripts|data)/ - [F,L]

# Friendly URL: /admin -> /admin.php
RewriteRule ^admin/?$ admin.php [L,QSA,NC]

# Friendly URL: /openen/<huisnummer> -> /open-house.php?house_number=<huisnummer>
RewriteRule ^openen/([0-9]{3})/?$ open-house.php?house_number=$1 [L,QSA,NC]

# Friendly URL: /<huisnummer> -> /ring-house.php?house_number=<huisnummer>
RewriteRule ^([0-9]{3})/?$ ring-house.php?house_number=$1 [L,QSA,NC]

# Friendly hidden URL: /_aanmelden_ -> /register.php
RewriteRule ^_aanmelden_/?$ register.php [L,QSA,NC]

# Redirect direct register.php access to hidden path
RewriteCond %{THE_REQUEST} \s/+register\.php(?:[\s?]|$) [NC]
RewriteRule ^register\.php$ /_aanmelden_ [R=302,L,NC]

# Statische assets en php pagina's direct serveren
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
