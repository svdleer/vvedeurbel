RewriteEngine On

# Beveilig broncode mappen
RewriteRule ^(src|migrations|scripts|data)/ - [F,L]

# Friendly URL: /admin -> /admin.php
RewriteRule ^admin/?$ admin.php [L,QSA,NC]

# Statische assets en php pagina's direct serveren
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
